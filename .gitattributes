# 统一所有文件的行尾符为 LF（跨平台协作必需）
* text=auto

# 这些文件类型必须是 LF
*.py     text eol=lf
*.toml   text eol=lf
*.yml     text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.sh     text eol=lf

# 二进制文件不过问行尾符
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.db     binary
*.egg-info/* binary
